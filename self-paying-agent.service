[Unit]
Description=Self-Paying Agent - Autonomous Crypto Trading Bot
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/workspace-luca/projects/self-paying-agent
Environment=NODE_ENV=production
Environment=SUI_NETWORK=testnet
Environment=LOG_LEVEL=info
ExecStart=/usr/bin/npx ts-node src/agent.ts
Restart=always
RestartSec=10
StandardOutput=append:/var/log/self-paying-agent.log
StandardError=append:/var/log/self-paying-agent.log

# Security
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/root/.openclaw/workspace-luca/projects/self-paying-agent/logs

[Install]
WantedBy=multi-user.target
